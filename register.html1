<!DOCTYPE html>
<html>
<head>
    <title>Register</title>

    <style>
        body {
            font-family: Arial;
            margin: 0;
            height: 100vh;

            display: flex;
            justify-content: center;
            align-items: center;
            background: #f5f5f5;
        }

        .form-section {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
            text-align: center;
        }

        input, select {
            display: block;
            width: 250px;
            margin: 10px auto;
            padding: 10px;
        }

        button {
            padding: 10px 20px;
            background: blue;
            color: white;
            border: none;
        }
    </style>
</head>

<body>

<section class="form-section">
    <h2>Register Now</h2>

    <form action="https://formspree.io/f/mlgwknke" method="POST">
        <input type="text" name="name" placeholder="Your Name" required>
        <input type="email" name="email" placeholder="Your Email" required>
        <input type="text" name="college" placeholder="College Name" required>

        <select name="event" required>
            <option value="">Select Event</option>
           <option>Paper Presentation</option>
            <option>Fixedwing</option>
            <option>Dronecoding</option>
            <option>Rocketry</option>
        </select>

        <button type="submit">Submit Registration</button>
    </form>
</section>

</body>
</html>
